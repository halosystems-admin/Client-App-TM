{
  "name": "halo-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:server": "nodemon --watch server --ext ts,json --exec ts-node server/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "if [ \"$IS_FRONTEND\" = \"true\" ]; then cd client && npm install && npm run build; else tsc; fi",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "if [ \"$IS_FRONTEND\" = \"true\" ]; then cd client && npm start; else node dist/server/index.js; fi"
  },
  
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@google/generative-ai": "^0.24.1",
    "@types/helmet": "^0.0.48",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "docx": "^9.5.1",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.2.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/session-file-store": "^1.2.6",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
