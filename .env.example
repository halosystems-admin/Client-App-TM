# ===========================================
# Halo Patient Concierge - Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Google OAuth 2.0 ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- URLs ---
# Frontend URL (CORS + post-OAuth redirect). Set this on Heroku as FRONTEND_URL.
FRONTEND_URL=http://localhost:5173
# Legacy alias; used if FRONTEND_URL is unset
CLIENT_URL=http://localhost:5173

# Production URL (used for OAuth redirect in production)
# PRODUCTION_URL=https://your-domain.com

# --- Notes / Templates (optional) ---
# FastAPI base URL for template retrieval and note generation (e.g. http://localhost:8000).
# When set, Settings shows "From practice" templates and the editor shows "Generate from template".
# NOTES_API_URL=

# --- Halo Functions API ---
HALO_API_BASE_URL=https://halo-functions-75316778879.africa-south1.run.app
HALO_USER_ID=cae6877e-0fbe-4ea1-acce-39957e7575bc
HALO_MOBILE_USER_ID=fcb5cfec-e10e-4c3a-bd44-064a788a6243
HALO_MOBILE_TEMPLATE_ID=report

# --- Feature flags (frontend) ---
VITE_ENABLE_EXPANDED_CALENDAR=true

# --- Google Calendar bookings (optional) ---
# BOOKINGS_CALENDAR_ID=your-bookings-calendar-id@group.calendar.google.com

# --- Template request email (optional) ---
# ADMIN_EMAIL=admin@halo.africa
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
